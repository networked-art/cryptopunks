{
  "name": "@networked-art/punks-indexer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "ponder dev",
    "start": "ponder start",
    "serve": "ponder serve",
    "db": "ponder db",
    "codegen": "ponder codegen && prettier --write .",
    "typecheck": "tsc && prettier --write .",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "drizzle:push": "drizzle-kit push",
    "postgres:up": "docker compose up -d",
    "postgres:down": "docker compose down",
    "postgres:reset": "docker compose down -v && docker compose up -d",
    "restore:fork": "bash scripts/restore-fork.sh",
    "start:fork": "bash scripts/start-fork.sh",
    "start:fork:fresh": "bash scripts/start-fork-fresh.sh",
    "kamal:setup": "set -a && . ./.env.production && set +a && kamal setup",
    "kamal:deploy": "set -a && . ./.env.production && set +a && kamal deploy",
    "kamal:sh": "set -a && . ./.env.production && set +a && kamal app exec -i --reuse sh"
  },
  "dependencies": {
    "@1001-digital/ponder-ens": "^0.1.0",
    "@networked-art/punks-sdk": "workspace:*",
    "@ponder/utils": "^0.2.18",
    "abitype": "^0.10.2",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.5.0",
    "ponder": "^0.16.6",
    "viem": "^2.21.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.30.6",
    "eslint": "^8.54.0",
    "eslint-config-ponder": "^0.16.6",
    "tsx": "^4.19.3",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.14"
  }
}
