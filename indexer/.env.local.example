# --- RPC ---
# For local fork mode, point at the hardhat node started by `pnpm dev:fork`
# in the `contracts` package. It serves chainId=1 (matching
# `ponder.config.ts`) and has the seed transfers mined on top.
PONDER_RPC_URLS_1=http://127.0.0.1:8545
PONDER_RPC_FALLBACK_URLS_1=
# Hardhat node doesn't expose a websocket — leave empty.
PONDER_WS_URL_1=

# --- Database ---
DATABASE_URL=postgresql://punks:punks@localhost:5412/punks
# Pin to the schema baked into the restored snapshot. `pnpm restore:fork`
# prints the exact value after restoring. Without this Ponder would derive
# a new schema from the local git HEAD and re-index from scratch.
DATABASE_SCHEMA=ponder_c896f90a9aa189f5
PONDER_VIEWS_SCHEMA=punks
