# Upstream JSON-RPC URL for mainnet reads. Server-only — never exposed to the
# browser; the same-origin /api/rpc proxy forwards calls here. The default in
# nuxt.config.ts embeds an API key, so override per environment.
NUXT_RPC_URL=https://eth-mainnet.example/v1/<api-key>

# WalletConnect Cloud project ID. Required for the WalletConnect connector;
# leave blank to disable WC and use injected/browser wallets only.
NUXT_PUBLIC_EVM_WALLET_CONNECT_PROJECT_ID=

# Public indexer base URL (Ponder/Postgres GraphQL endpoint). Defaults to the
# production indexer in nuxt.config.ts; override per environment.
NUXT_PUBLIC_INDEXER_URL=https://indexer.punks.auction

# Broker brand shown in the "branded" Contact-broker preview. Defaults to
# "Canon" in nuxt.config.ts. NUXT_PUBLIC_BROKER_LOGO is inline SVG markup —
# use fill="currentColor" so it inherits the surrounding text color.
NUXT_PUBLIC_BROKER_NAME=Canon
NUXT_PUBLIC_BROKER_LOGO=<svg viewBox="0 0 234 45" xmlns="http://www.w3.org/2000/svg"><path d="..." fill="currentColor"/></svg>
