# Deployment
DOCKER_REGISTRY_USERNAME=
DEPLOY_HOST=
APP_HOST=

NUXT_PUBLIC_PUBLIC_URL=https://punks.auction

# Site origin for nuxt-site-config (used by nuxt-og-image for absolute URLs)
NUXT_SITE_URL=https://punks.auction

# Upstream JSON-RPC URL (server-only, proxied via /api/rpc)
NUXT_RPC_URL=

# WalletConnect Cloud project ID
NUXT_PUBLIC_EVM_WALLET_CONNECT_PROJECT_ID=

# Public indexer base URL (Ponder/Postgres GraphQL endpoint)
NUXT_PUBLIC_INDEXER_URL=https://indexer.punks.auction

# Optional networked.art API base URL — enables off-chain features (brokerage
# requests, and later notifications). Leave empty to disable.
NUXT_PUBLIC_NETWORKED_API_URL=
