<!doctype html>
<html>
  <body style="font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; background: #0a0a0a; color: #e5e5e5; padding: 32px;">
    <table cellpadding="0" cellspacing="0" border="0" style="max-width: 480px; margin: 0 auto;">
      <tr>
        <td>
          <h1 style="font-size: 18px; margin: 0 0 16px 0;">Inquiry update</h1>
          <p style="margin: 0 0 16px 0;">Your inquiry <strong>#{{ inquiryId }}</strong> is now <strong style="color: #5cf;">{{ status }}</strong>.</p>
          <p style="font-size: 12px; color: #888; margin: 0;">
            <a href="{{ publicUrl }}" style="color: #5cf;">{{ publicUrl }}</a>
          </p>
        </td>
      </tr>
    </table>
  </body>
</html>
