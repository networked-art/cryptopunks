<!doctype html>
<html>
  <body style="font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; background: #0a0a0a; color: #e5e5e5; padding: 32px;">
    <table cellpadding="0" cellspacing="0" border="0" style="max-width: 480px; margin: 0 auto;">
      <tr>
        <td>
          <h1 style="font-size: 18px; margin: 0 0 8px 0;">CryptoPunk #{{ punkId }}</h1>
          <p style="margin: 0 0 16px 0; color: #aaa;">Matches your saved search: <strong style="color: #fff;">{{ searchName }}</strong></p>
          <p style="margin: 0 0 16px 0;">{{ kind }} on {{ source }}</p>
          @if(listingWei || weiAmount)
            <p style="margin: 0 0 16px 0;">Amount: {{ listingWei || weiAmount }} wei</p>
          @end
          <p style="margin: 0 0 24px 0;">
            <a href="https://etherscan.io/tx/{{ txHash }}" style="color: #5cf;">View transaction</a>
          </p>
          <p style="font-size: 12px; color: #888; margin: 0;">
            You're receiving this because you enabled notifications for this saved search.
            Manage your searches at <a href="{{ publicUrl }}" style="color: #5cf;">{{ publicUrl }}</a>.
          </p>
        </td>
      </tr>
    </table>
  </body>
</html>
