{
  "name": "@networked-art/punks-offchain",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "test": "node ace test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#mailers/*": "./app/mailers/*.js",
    "#models/*": "./app/models/*.js",
    "#services/*": "./app/services/*.js",
    "#transformers/*": "./app/transformers/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#jobs/*": "./app/jobs/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#commands/*": "./commands/*.js",
    "#database/*": "./database/*.js",
    "#tests/*": "./tests/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/assert": "^4.2.0",
    "@japa/plugin-adonisjs": "^5.1.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/luxon": "^3.7.1",
    "@types/node": "~24.11.0",
    "@types/pg": "^8.20.0",
    "eslint": "^10.0.2",
    "hot-hook": "^1.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "youch": "^4.1.0"
  },
  "dependencies": {
    "@adonisjs/auth": "^10.1.0",
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/lucid": "^22.0.0",
    "@adonisjs/mail": "^10.2.0",
    "@adonisjs/queue": "^0.6.0",
    "@adonisjs/session": "^8.0.0",
    "@adonisjs/shield": "^9.0.0",
    "@japa/api-client": "^3.2.1",
    "@networked-art/punks-sdk": "workspace:*",
    "@signinwithethereum/siwe": "^4.2.0",
    "@vinejs/vine": "^4.3.0",
    "better-sqlite3": "^12.6.2",
    "edge.js": "^6.5.0",
    "luxon": "^3.7.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "viem": "^2.48.0"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
