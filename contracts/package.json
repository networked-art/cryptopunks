{
  "name": "@networked-art/punks-contracts",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "generate:punks-data": "hardhat run scripts/generate-punks-data.ts",
    "snapshot:source": "hardhat run scripts/snapshot-source.ts",
    "analyze:rarest-punk-colors": "hardhat run scripts/analyze-rarest-punk-colors.ts",
    "analyze:punks-deflate": "hardhat run scripts/analyze-punks-deflate.ts",
    "verify:punks-png": "hardhat run scripts/verify-punks-png.ts",
    "verify:punks-png:deflate-block": "hardhat run scripts/verify-punks-png-deflate-block.ts",
    "verify:punks-png:composite-chunks": "hardhat run scripts/verify-punks-png-composite-chunks.ts",
    "load:punks-data": "hardhat run scripts/load-punks-data.ts --network mainnet",
    "seal:punks-data": "PUNKS_DATA_SEAL=1 hardhat run scripts/load-punks-data.ts --network mainnet",
    "test": "hardhat test",
    "test:gas": "hardhat --gas-stats test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition": "^3.1.5",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.5",
    "@openzeppelin/contracts": "^5.6.1",
    "@types/node": "^22.19.11",
    "hardhat": "^3.4.5",
    "typescript": "~5.8.3",
    "viem": "^2.48.11"
  }
}
