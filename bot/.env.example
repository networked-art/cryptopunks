# Set to "true" to skip Twitter and instead print each tweet and write its grid
# image to a temp file. No credentials needed in dry run.
DRY_RUN=true

# Twitter/X OAuth 1.0a user-context credentials. Only required when DRY_RUN is
# unset. API key/secret are the app's "Consumer Keys"; the access token/secret
# are generated per-account in the X developer portal (Keys and tokens) with the
# app set to Read and Write. (The app-only Bearer Token cannot post and is unused.)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Ponder indexer GraphQL endpoint. Defaults to the deployed indexer.
INDEXER_URL=https://indexer.punksmarket.app

# Optional Ethereum RPC for ENS name resolution. Without it, accounts show as a
# curated label (if any) or a shortened address.
RPC_URL=

# Optional: skip acquisitions whose total spend is below this many wei.
# MIN_SPEND_WEI=

# Optional: target grid width in pixels (default 1920).
# GRID_MAX_WIDTH=1920
