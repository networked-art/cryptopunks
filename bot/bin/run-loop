#!/bin/sh
# Polls roughly once per Ethereum block (~12s). A non-blocking flock keeps
# exactly one tick running at a time: if a tick is still computing or posting
# when the next poll comes due, that poll is skipped rather than overlapping —
# so a slow burst never double-posts. Keeping the loop in the shell means every
# tick starts from clean state and a crash can't wedge an in-memory timer.
#
# Output is intentionally quiet (no per-tick banner) since at this cadence the
# bot only logs when it actually does something; container health covers liveness.

INTERVAL="${POLL_INTERVAL:-12}"
LOCK_FILE="${LOCK_FILE:-/tmp/punks-bot.lock}"

while true; do
  START=$(date +%s)

  # -n: don't wait for the lock — if a prior tick still holds it, skip this poll.
  flock -n "$LOCK_FILE" node --import tsx src/index.ts \
    || echo "[$(date -u '+%Y-%m-%d %H:%M:%S')] tick skipped (busy) or failed"

  # Sleep only the remainder of the interval, so the cadence stays ~INTERVAL
  # instead of INTERVAL + tick time; a tick longer than INTERVAL just runs the
  # next one back-to-back.
  ELAPSED=$(($(date +%s) - START))
  if [ "$ELAPSED" -lt "$INTERVAL" ]; then
    sleep "$((INTERVAL - ELAPSED))"
  fi
done
