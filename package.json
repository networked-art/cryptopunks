{
  "name": "@networked/cryptopunks",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "test": "pnpm --filter @networked-art/punks-contracts test && pnpm --filter @networked-art/punks-sdk test",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "docs:dev": "pnpm --filter @networked-art/punks-docs dev",
    "docs:build": "pnpm --filter @networked-art/punks-docs build",
    "docs:preview": "pnpm --filter @networked-art/punks-docs preview"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "prettier": "^3.8.1"
  },
  "pnpm": {
    "overrides": {
      "viem": "2.48.4"
    }
  }
}
