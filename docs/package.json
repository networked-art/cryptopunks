{
  "name": "@cryptopunks/docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vitepress dev",
    "build": "vitepress build",
    "preview": "vitepress preview",
    "kamal:setup": "set -a && . ./.env.production && set +a && kamal setup",
