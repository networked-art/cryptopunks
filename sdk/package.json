{
  "name": "@networked-art/punks-sdk",
  "version": "0.0.1-alpha.0",
  "description": "Collection-first TypeScript SDK for CryptoPunks search, rendering, market actions, and auctions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/networked-art/cryptopunks.git",
    "directory": "sdk"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./offline": {
      "types": "./dist/offline.d.ts",
      "import": "./dist/offline.js"
    },
    "./offline-data": {
      "types": "./dist/offline-data.d.ts",
      "import": "./dist/offline-data.js"
    },
    "./offline-pixel-data": {
      "types": "./dist/offline-pixel-data.d.ts",
      "import": "./dist/offline-pixel-data.js"
    },
    "./similarity": {
      "types": "./dist/similarity.d.ts",
      "import": "./dist/similarity.js"
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm clean && tsc -p tsconfig.build.json && vite build",
    "test": "pnpm build && pnpm typecheck:api && node --test test/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:api": "tsc --noEmit -p tsconfig.api-test.json"
  },
  "peerDependencies": {
    "viem": "^2.48.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "typescript": "~5.8.3",
    "viem": "^2.48.11",
    "vite": "^5.4.21"
  }
}
