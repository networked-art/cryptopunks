# Database shared with the indexer.
DATABASE_URL=postgresql://punks:punks@localhost:5412/punks

# Stable Ponder views schema exposed by the indexer.
PONDER_VIEWS_SCHEMA=punks

# Local scheduler defaults. `uv run punk-predictor run` ignores these.
PREDICTOR_RUN_ON_START=true
PREDICTOR_SCHEDULE_HOUR_UTC=3
